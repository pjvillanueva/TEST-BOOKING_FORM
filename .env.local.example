# Google Maps API key (required for distance + travel time).
# Enable "Routes API" at https://console.cloud.google.com/apis/library/routes.googleapis.com
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Same key exposed to browser for Places Autocomplete (address suggestions as you type).
# In Google Cloud, enable: "Maps JavaScript API" and "Places API (New)" for this project.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
